  "description": "PR review agent server using @mariozechner/pi-coding-agent",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file .env --import ./app/otel.ts app/server.ts",
    "start": "tsx --import ./app/otel.ts app/server.ts"
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.10",
