# PostgreSQL — same DB as the Python bot or a separate one
DATABASE_URL=postgresql://user:pass@localhost:5432/litellm_bot

# Cursor SDK (LLM provider for triage / pattern / karpathy / chat)
CURSOR_API_KEY=crs-...
CURSOR_MODEL=claude-sonnet-4-6
# Optional repo override; defaults to https://github.com/BerriAI/litellm
# CURSOR_REPO_URL=https://github.com/BerriAI/litellm

# LiteLLM proxy — used as the GitHub MCP gateway by the Python gather scripts
# (gather_pr_triage_data.py). NOT used as an LLM provider since the Cursor SDK
# migration. Leave set if you want triage gather to keep working.
LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=sk-...

# Auth (both optional — disables auth gate if unset)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secret
BOT_API_KEYS=key1,key2
SESSION_SECRET=some-random-string

# GitHub token — used by gather_pattern_e2b.ts to clone private repos / avoid
# rate limits. Also accepted by gather_pattern_local.ts via gh CLI. Bypasses
# the LiteLLM MCP proxy when set.
# GITHUB_TOKEN=ghp_...

# E2B — when set, pattern gather runs in an isolated E2B sandbox with Claude
# Code CLI instead of a local git clone (removes LITELLM_CLONE_DIR dependency).
# Get a key at https://e2b.dev
# E2B_API_KEY=e2b_...
# ANTHROPIC_API_KEY=sk-ant-...  # forwarded into the e2b sandbox

PORT=8081

# GitHub webhook secret — set in repo/org Settings → Webhooks → Secret
# Endpoint: POST /webhook/github
# If unset, signature verification is skipped (dev only — set in prod)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Slack daily merge summary (optional)
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# and paste the URL below. Leave unset to disable.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# SLACK_DAILY_SUMMARY_HOUR_UTC=17   # 0–23, default 17 (5 PM UTC)
